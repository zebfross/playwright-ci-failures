{
  "name": "playwright-ci-failures",
  "displayName": "Playwright CI Failures",
  "description": "Browse Playwright e2e failures from GitHub Actions runs — error, screenshot, and video — without downloading artifacts by hand.",
  "version": "0.1.2",
  "publisher": "zebfross",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zebfross/playwright-ci-failures.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onView:pwciRuns"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "pwci.show", "title": "Show CI Failures", "category": "Playwright CI" },
      { "command": "pwci.refreshRuns", "title": "Refresh Runs", "category": "Playwright CI", "icon": "$(refresh)" }
    ],
    "views": {
      "scm": [
        { "id": "pwciRuns", "name": "Playwright CI Failures" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pwciRuns",
        "contents": "Browse Playwright e2e failures from your GitHub Actions runs.\n[Show CI Failures](command:pwci.show)"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "pwci.refreshRuns", "when": "view == pwciRuns", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "Playwright CI Failures",
      "properties": {
        "pwci.repo": {
          "type": "string",
          "default": "",
          "markdownDescription": "`owner/repo` override. Empty = detect from the workspace's `origin` git remote."
        },
        "pwci.workflow": {
          "type": "string",
          "default": "",
          "markdownDescription": "Workflow file name (e.g. `deploy.yml`) to filter runs by. Empty = all workflows."
        },
        "pwci.pollSeconds": {
          "type": "number",
          "default": 15,
          "markdownDescription": "How often (in seconds) to auto-refresh the run list while the panel is visible. Set to `0` to disable live updates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "install:local": "npm run package && code --install-extension \"$(ls -t *.vsix | head -n1)\" --force"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.6.0"
  }
}
